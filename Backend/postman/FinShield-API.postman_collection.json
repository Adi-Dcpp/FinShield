    {
      "name": "06. End-to-End Flow Validation",
      "item": [
        {
          "name": "E2E - Confirm History Contains SUCCESS/FAILED",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{fakeUserName}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/history",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "history"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "const statuses = (body.data || []).map(tx => tx.status);",
                  "pm.test('history includes at least one SUCCESS and one FAILED in dev flow', function () {",
                  "  pm.expect(statuses.includes('SUCCESS')).to.eql(true);",
                  "  pm.expect(statuses.includes('FAILED')).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
