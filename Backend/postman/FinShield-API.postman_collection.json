{
  "info": {
    "name": "FinShield API - Dev Regression Suite",
    "description": "Comprehensive Postman suite for realistic backend testing. Includes smoke, positive, boundary, negative, and stateful flow scenarios for transactions API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "f49f89c0-d5f7-46a2-b40f-1f45d6d7361a"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('baseUrl')) pm.environment.set('baseUrl', 'http://localhost:3000/api/v1');",
          "if (!pm.environment.get('fakeUserName')) pm.environment.set('fakeUserName', 'Aarav Sharma');",
          "if (!pm.environment.get('fakeUserTwo')) pm.environment.set('fakeUserTwo', 'Priya Verma');",
          "pm.collectionVariables.set('runId', String(Date.now()));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01. Smoke",
      "item": [
        {
          "name": "Health - Service Up",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('health status is ok', function () { pm.expect(body.status).to.eql('ok'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02. Review API",
      "item": [
        {
          "name": "Review - Safe Baseline",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{fakeUserName}}\",\n  \"amount\": 1200,\n  \"deviceId\": \"dev-aa-01\",\n  \"city\": \"Delhi\",\n  \"merchant\": \"Amazon\",\n  \"timeStamp\": \"{{$isoTimestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/review",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "review"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('schema-like checks', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data).to.have.property('riskPoint');",
                  "  pm.expect(body.data).to.have.property('riskFactors');",
                  "  pm.expect(body.data).to.have.property('decision');",
                  "  pm.expect(body.data).to.have.property('meta');",
                  "  pm.expect(body.data.explanation).to.be.a('string');",
                  "});",
                  "pm.collectionVariables.set('safeName', pm.environment.get('fakeUserName'));",
                  "pm.collectionVariables.set('safeRiskPoint', String(body.data.riskPoint));",
                  "pm.collectionVariables.set('safeRiskFactors', JSON.stringify(body.data.riskFactors));",
                  "pm.collectionVariables.set('safeMeta', JSON.stringify(body.data.meta));"
                ]
              }
            }
          ]
        },
        {
          "name": "Review - Risky Transaction (High)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{fakeUserName}}\",\n  \"amount\": 125000,\n  \"deviceId\": \"dev-aa-unknown-{{runId}}\",\n  \"city\": \"London\",\n  \"merchant\": \"Crypto Wallet Transfer\",\n  \"timeStamp\": \"2026-03-27T01:30:00.000Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/review",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "review"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('high-risk expectation', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data.riskPoint).to.be.at.least(70);",
                  "  pm.expect(['REVIEW', 'BLOCK']).to.include(body.data.decision);",
                  "});",
                  "pm.collectionVariables.set('riskName', pm.environment.get('fakeUserName'));",
                  "pm.collectionVariables.set('riskPoint', String(body.data.riskPoint));",
                  "pm.collectionVariables.set('riskFactors', JSON.stringify(body.data.riskFactors));",
                  "pm.collectionVariables.set('riskMeta', JSON.stringify(body.data.meta));"
                ]
              }
            }
          ]
        },
