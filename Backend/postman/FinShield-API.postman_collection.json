                  "pm.test('history returns array and max 20', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data).to.be.an('array');",
                  "  pm.expect(body.data.length).to.be.at.most(20);",
                  "});",
                  "if (body.data.length > 0) {",
                  "  pm.test('history item has key fields', function () {",
