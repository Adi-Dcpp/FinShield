{
  "info": {
    "name": "FinShield Complete API - Edge & Regression Suite",
    "description": "Complete Postman suite for all current backend routes: health, transactions, and messages/check. Includes happy paths, validation negatives, boundaries, malformed payloads, method errors, and stateful flow assertions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "5f1ef8be-3f5a-4fc2-b9b0-a788dcbf4f20"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('baseUrl')) pm.environment.set('baseUrl', 'http://localhost:3000/api/v1');",
          "if (!pm.environment.get('fakeUserName')) pm.environment.set('fakeUserName', 'Aarav Sharma');",
          "if (!pm.environment.get('fakeUserTwo')) pm.environment.set('fakeUserTwo', 'Priya Verma');",
          "pm.collectionVariables.set('runId', String(Date.now()));",
          "if (!pm.collectionVariables.get('safeMeta')) pm.collectionVariables.set('safeMeta', '{}');",
          "if (!pm.collectionVariables.get('riskMeta')) pm.collectionVariables.set('riskMeta', '{}');",
          "if (!pm.collectionVariables.get('safeRiskFactors')) pm.collectionVariables.set('safeRiskFactors', '[]');",
          "if (!pm.collectionVariables.get('riskFactors')) pm.collectionVariables.set('riskFactors', '[]');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01. Smoke",
      "item": [
        {
          "name": "GET /health - service up",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('health payload', function () { pm.expect(body.status).to.eql('ok'); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02. Transactions - Review",
      "item": [
        {
          "name": "POST /transactions/review - safe baseline",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{fakeUserName}}\",\n  \"amount\": 1200,\n  \"deviceId\": \"dev-aa-01\",\n  \"city\": \"Delhi\",\n  \"merchant\": \"Amazon\",\n  \"timeStamp\": \"{{$isoTimestamp}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/review",
              "host": ["{{baseUrl}}"],
              "path": ["transactions", "review"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "const body = pm.response.json();",
                  "pm.test('core fields present', function () {",
                  "  pm.expect(body.success).to.eql(true);",
                  "  pm.expect(body.data.riskPoint).to.be.within(0, 100);",
                  "  pm.expect(['APPROVE', 'REVIEW', 'BLOCK']).to.include(body.data.decision);",
                  "  pm.expect(body.data.riskFactors).to.be.an('array');",
                  "  pm.expect(body.data.meta).to.be.an('object');",
                  "});",
                  "pm.collectionVariables.set('safeRiskPoint', String(body.data.riskPoint));",
                  "pm.collectionVariables.set('safeRiskFactors', JSON.stringify(body.data.riskFactors));",
                  "pm.collectionVariables.set('safeMeta', JSON.stringify(body.data.meta));"
                ]
              }
            }
          ]
        },
